<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="#E0E0E0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Ligne du haut : Titre et Date -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <!-- Petite icône officielle (optionnel) -->
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_dialog_info"
                android:layout_gravity="center"
                app:tint="#004A99"
                android:layout_marginEnd="8dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- ID EXACT DU KOTLIN : tvTitreCommunique -->
                <TextView
                    android:id="@+id/tvTitreCommunique"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Travaux de maintenance"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <!-- ID EXACT DU KOTLIN : tvDateCommunique -->
                <TextView
                    android:id="@+id/tvDateCommunique"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10/04/2026 14:30"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Séparateur -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginBottom="12dp"/>

        <!-- ID EXACT DU KOTLIN : tvMessageCommunique -->
        <TextView
            android:id="@+id/tvMessageCommunique"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nous informons les populations de la zone de Koulouba qu'une coupure de courant aura lieu ce soir..."
            android:textSize="15sp"
            android:textColor="#555555"
            android:lineSpacingExtra="2dp"
            android:maxLines="3"
            android:ellipsize="end"/>

        <!-- Ligne du bas : Bouton Partager -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:layout_marginTop="12dp">

            <!-- ID EXACT DU KOTLIN : btnShare -->
            <ImageButton
                android:id="@+id/btnShare"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_share"
                android:contentDescription="Partager"
                app:tint="#004A99"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>